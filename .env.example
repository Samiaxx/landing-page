ARIONPAY_STORE_ID=your_arionpay_store_id
ARIONPAY_API_KEY=your_arionpay_api_key
ARIONPAY_API_SECRET=your_arionpay_api_secret
ARIONPAY_FIAT_CURRENCY=EUR

# Durable order storage for Vercel / serverless deployments
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Optional local filesystem override for non-serverless development
PRIMUS_DATA_DIR=

# Optional auth/session tuning
PRIMUS_AUTH_SESSION_DAYS=7
PRIMUS_AUTH_MAX_LOGIN_ATTEMPTS=5
PRIMUS_AUTH_LOCK_MINUTES=15

# Email configuration
# Use EMAIL_PROVIDER=auto to prefer Resend, then Brevo API, then Brevo SMTP.
# Supported values: auto, resend, brevo-api, brevo-smtp, disabled
EMAIL_PROVIDER=brevo-smtp
EMAIL_FROM_NAME=Primus Peptides
EMAIL_FROM=noreply@peptidos-primus.com
EMAIL_REPLY_TO=contact@peptidos-primus.com
SUPPORT_EMAIL=contact@peptidos-primus.com
ADMIN_EMAIL=admin@peptidos-primus.com

# Brevo SMTP (recommended when using the Brevo SMTP settings panel)
BREVO_SMTP_HOST=smtp-relay.brevo.com
BREVO_SMTP_PORT=587
BREVO_SMTP_USER=your_brevo_smtp_login
BREVO_SMTP_PASS=your_brevo_smtp_password
BREVO_SMTP_SECURE=false

# Optional Brevo API alternative
BREVO_API_KEY=your_brevo_api_key

# Optional Resend alternative
RESEND_API_KEY=your_resend_api_key

# Production email deliverability note:
# Verify the sender domain with your provider and add the required SPF, DKIM,
# and DMARC DNS records before sending from a custom domain.
